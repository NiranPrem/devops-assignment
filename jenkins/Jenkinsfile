pipeline {
agent {
label 'k3s'
}

```
options {
    timeout(time: 30, unit: 'MINUTES')
    buildDiscarder(logRotator(numToKeepStr: '10'))
}

stages {

    stage('Checkout') {
        steps {
            checkout scm
        }
    }

    stage('Validate Repository') {
        steps {
            sh '''
            pwd
            ls -la

            test -d app
            test -d k8s
            test -f docker-compose.yml

            echo "Repository validation passed"
            '''
        }
    }

    stage('Build API Image') {
        steps {
            sh '''
            docker build \
              -t devops-assignment/api:dev \
              ./app/api
            '''
        }
    }

    stage('Build Web Image') {
        steps {
            sh '''
            docker build \
              -t devops-assignment/web:dev \
              ./app/web
            '''
        }
    }

    stage('Import Images To K3s') {
        steps {
            sh '''
            docker save devops-assignment/api:dev -o api.tar
            docker save devops-assignment/web:dev -o web.tar

            sudo k3s ctr images import api.tar
            sudo k3s ctr images import web.tar
            '''
        }
    }

    stage('Deploy DEV') {
        steps {
            sh '''
            kubectl apply -k k8s/overlays/dev

            kubectl rollout status deployment/api -n dev --timeout=180s
            kubectl rollout status deployment/web -n dev --timeout=180s
            '''
        }
    }

    stage('Smoke Test DEV') {
        steps {
            sh '''
            kubectl get pods -n dev

            kubectl wait \
              --for=condition=Ready \
              pod \
              -l app=api \
              -n dev \
              --timeout=120s

            kubectl wait \
              --for=condition=Ready \
              pod \
              -l app=web \
              -n dev \
              --timeout=120s
            '''
        }
    }

    stage('Deploy QAT') {
        steps {
            sh '''
            kubectl apply -k k8s/overlays/qat

            kubectl rollout status deployment/api -n qat --timeout=180s
            kubectl rollout status deployment/web -n qat --timeout=180s
            '''
        }
    }

    stage('Validate Rollout') {
        steps {
            sh '''
            echo "===== DEV ====="
            kubectl get pods -n dev
            kubectl get svc -n dev

            echo "===== QAT ====="
            kubectl get pods -n qat
            kubectl get svc -n qat
            '''
        }
    }
}

post {
    success {
        echo 'CI/CD Pipeline Completed Successfully'
    }

    failure {
        echo 'Pipeline Failed'

        sh '''
        kubectl rollout undo deployment/api -n dev || true
        kubectl rollout undo deployment/web -n dev || true

        kubectl rollout undo deployment/api -n qat || true
        kubectl rollout undo deployment/web -n qat || true
        '''
    }
}
```

}
